# APP
APP_PORT=8080

# DB (matches docker-compose service `db` when running in Compose)
DB_NAME=microWeb
DB_USER=microWebUser
DB_PASS=microWebPassword
DB_PORT=3306
DB_HOST=db
DB_DRIVER=mysql

# If true, inserts demo rows only when the sites table is empty.
SEED_DEMO_DATA=true

# If true, drops the sites table before migrate (destructive; local/dev only).
RESET_DB_ON_STARTUP=false
